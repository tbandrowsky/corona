{
  "class_name": "page",
  "page_name": "card_client",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\client.png",
      "$card_height": "75 pixels",
      "$card_contents": [
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "company_name",
          "text_style": {
            "font_size": 16,
            "bold": true
          },
          "text": "{company_name}"
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "contact",
          "text": "{contact} - {city}, {state}"
        }
      ]
    }
  }
}
