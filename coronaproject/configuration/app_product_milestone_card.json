{
  "class_name": "page",
  "page_name": "page_product_milestone_card",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\milestone.png",
      "$card_height": "75 pixels",
      "$details_contents": [
        {
          "class_name": "paragraph",
          "json_field_name": "name",
          "text": "{name}",
          "box": "card_text_box"
        },
        {
          "class_name": "paragraph",
          "json_field_name": "url",
          "text": "{url}",
          "box": "card_text_box"
        }
      ]
    }
  }
}
