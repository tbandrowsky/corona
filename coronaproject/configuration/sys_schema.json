{
  "schema_name": "Revolution Arcade",
  "schema_description": "Revolution Arcade Application Schema",
  "schema_version": "1.1",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "datasets": [
    {
      "dataset_name": "Revolution Arcade Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical, and the use of sys_team means it can go first",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "app_team",
          "team_description": "Local security for teams",
          "team_domain": "localhost.com",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "app_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ],
  "classes": [
    {
      "class_name": "game_activity",
      "base_class_name": "sys_object",
      "class_description": "An activity",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "Description"
        },
        "image": "bitmap"
      }
    },
    {
      "class_name": "game_definition",
      "base_class_name": "activity",
      "class_description": "A game in the system",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "First Name"
        },
        "map": "map",
        "sessions": [ "session" ]
      },
      "indexes": {
        "game_name_index": {
          "index_keys": [ "name" ]
        }
      }
    },
    {
      "class_name": "game_essay",
      "base_class_name": "game_activity",
      "class_description": "An essay in the system",
      "full_text": [ "name", "description", "text" ],
      "fields": {
        "text": "string"
      }
    },
    {
      "class_name": "game_map",
      "base_class_name": "sys_object",
      "class_description": "a gaming map",
      "parents": [ "game", "session" ],
      "fields": {
        "image": "string",
        "pieces": [ "piece" ]
      }
    },
    {
      "class_name": "game_session",
      "base_class_name": "sys_object",
      "class_description": "a gaming session",
      "parents": [ "game_definition" ],
      "fields": {
        "map": "game_map",
        "name": {
          "field_type": "string",
          "label": "Name",
          "max_length": 100
        },
        "state": {
          "field_type": "string",
          "label": "State",
          "max_length": 20,
          "enumeration": [ "lobby", "active", "paused", "complete", "exit" ]
        },
        "description": {
          "field_type": "string",
          "label": "Description"
        }
      }
    },
    {
      "class_name": "animation_frame",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "piece_animation" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State"
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "time_point": "double",
        "destination": "rectangle",
        "carry_point": "vector",
        "sound": "audio"
      }
    },
    {
      "class_name": "animation_bitmap_frame",
      "base_class_name": "frame",
      "class_description": "a gaming piece of an image",
      "fields": {
        "image": "bitmap"
      }
    },
    {
      "class_name": "animation_vector_frame",
      "base_class_name": "frame",
      "class_description": "a gaming piece of an image",
      "fields": {
        "shape": "path",
        "fill": "brush",
        "stroke": "brush",
        "stroke_width": "double"
      }
    },
    {
      "class_name": "piece_animation",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "game_piece" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State"
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "destination": "rectangle",
        "direction": "vector",
        "sound": "audio",
        "frames": [ "animation_frame" ]
      }
    },
    {
      "class_name": "map_piece",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "game_map" ],
      "fields": {
        "name": "string",
        "image_name": {
          "field_type": "string",
          "label": "Image asset name",
          "max_length": 200
        },
        "position": "vector",
        "size": "vector",
        "velocity": "vector",
        "facing": "vector",
        "state": "string",
        "animations": [ "piece_animation" ],
        "mass": "double",
        "full_hit_points": "double",
        "hit_points": "double",
        "inventory": {
          "field_type": "chest",
          "item_class": "game_item"
        }
      }
    },
    {
      "class_name": "map_actor",
      "base_class_name": "map_piece",
      "class_description": "a gaming player",
      "fields": {
        "selection": "selection"
      }
    },
    {
      "class_name": "map_player",
      "base_class_name": "map_actor",
      "class_description": "a gaming player",
      "fields": {
        "input_device": "string"
      }
    },
    {
      "class_name": "map_npc",
      "base_class_name": "map_actor",
      "class_description": "a gaming NPC",
      "fields": {

      }
    },
    {
      "class_name": "map_feature",
      "base_class_name": "map_piece",
      "class_description": "a static feature on a map"
    },
    {
      "class_name": "map_loot_box",
      "base_class_name": "map_feature",
      "class_description": "a gaming loot box",
      "fields": {

      }
    },
    {
      "class_name": "map_loot_spot",
      "base_class_name": "map_feature",
      "class_description": "a gaming loot spot",
      "fields": {

      }
    },
    {
      "class_name": "map_switch",
      "base_class_name": "map_feature",
      "class_description": "a gaming switch",
      "fields": {

      }
    },
    {
      "class_name": "map_wall",
      "base_class_name": "map_feature",
      "class_description": "a gaming wall",
      "fields": {
        "passable": "boolean"
      }
    },
    {
      "class_name": "map_door",
      "base_class_name": "map_feature",
      "class_description": "a gaming door",
      "fields": {
        "open": "boolean"
      }
    },
    {
      "class_name": "map_surface",
      "base_class_name": "map_feature",
      "class_description": "a gaming surface",
      "fields": {
        "mechanic": "string",
        "acceleration_multiplier": "double",
        "friction_multiplier": "double"
      }
    },
    {
      "class_name": "decoration",
      "base_class_name": "map_feature",
      "class_description": "a gaming decoration, like clouds",
      "fields": {
      }
    },
    {
      "class_name": "camera",
      "base_class_name": "map_feature",
      "class_description": "A camera in the system",
      "fields": {
        "fov": "double",
        "near_clip": "double",
        "far_clip": "double"
      }
    },
    {
      "class_name": "spawn",
      "base_class_name": "map_feature",
      "class_description": "A place to launch players",
      "fields": {
      }
    },
    {
      "class_name": "npc_spawn",
      "base_class_name": "map_feature",
      "class_description": "A place to launch npcs",
      "fields": {
        "spawn_classes": [ "string" ],
        "frequency_seconds": "double",
        "remaining_seconds": "double"
      }
    },
    {
      "class_name": "player_spawn",
      "base_class_name": "map_feature",
      "class_description": "A place to launch players",
      "fields": {
      }
    },
    {
      "class_name": "map_item_type",
      "base_class_name": "sys_object",
      "class_description": "a type of an item",
      "fields": {
        "name": "string",
        "description": "string",
        "items": [ "item" ]
      }
    },
    {
      "class_name": "map_item",
      "base_class_name": "piece",
      "class_description": "an item to be used during the game",
      "parents": [ "game_map", "map_item_type" ],
      "fields": {
      }
    },
    {
      "class_name": "effect_type",
      "base_class_name": "map_item_type",
      "class_description": "a type of an effect",
      "fields": {
        "frequency_seconds": "double",
        "remaining_seconds": "double",
        "remaining_count": "double",
        "name": "string",
        "effect": [ "effect" ]
      }
    },
    {
      "class_name": "effect",
      "base_class_name": "map_item",
      "class_description": "a gaming item",
      "fields": {
        "frequency_seconds": "double",
        "remaining_seconds": "double",
        "remaining_count": "double",
        "name": "string"
      }
    },
    {
      "class_name": "tool_type",
      "base_class_name": "map_item",
      "class_description": "general activatable thing",
      "fields": {

      }
    },
    {
      "class_name": "firearm_type",
      "base_class_name": "tool_type",
      "class_description": "weapon for the shot",
      "fields": {
        "magazine": [ "magazine_type" ]
      }
    },
    {
      "class_name": "magazine_type",
      "base_class_name": "map_item_type",
      "class_description": "a magazine for the firearm",
      "parents": [ "firearm_type" ],
      "fields": {
        "ammunition": [ "ammunition_type" ],
        "magazines": [ "magazine" ]
      }
    },
    {
      "class_name": "ammunition_type",
      "base_class_name": "map_item_type",
      "class_description": "ammo for the firearm",
      "parents": [ "magazine_type" ],
      "fields": {
        "shot": [ "shot_type" ],
        "ammunition": [ "ammunition" ]
      }
    },
    {
      "class_name": "shot_type",
      "base_class_name": "map_item_type",
      "class_description": "an effect of a weapon",
      "fields": {
        "effect": [ "effect_type" ],
        "shots": [ "shot" ]
      }
    },
    {
      "class_name": "firearm",
      "base_class_name": "map_tool",
      "class_description": "weapon for the shot",
      "parents": [ "firearm_type" ],
      "fields": {

      }
    },
    {
      "class_name": "magazine",
      "base_class_name": "map_item",
      "class_description": "a magazine for the firearm",
      "parents": [ "firearm_type" ],
      "fields": {

      }
    },
    {
      "class_name": "ammunition",
      "base_class_name": "map_item",
      "class_description": "ammo for the firearm",
      "parents": [ "ammunition_type" ],
      "fields": {

      }
    },
    {
      "class_name": "shot",
      "base_class_name": "map_item",
      "class_description": "an effect of a weapon",
      "parents": [ "shot_type" ],
      "fields": {
        "effect": [ "effect_type" ]
      }
    },
    {
      "class_name": "wand_type",
      "base_class_name": "map_tool_type",
      "class_description": "a magic thing that launches spells",
      "fields": {
        "spells": [ "spell_type" ]
      }
    },
    {
      "class_name": "spell_type",
      "base_class_name": "map_tool",
      "class_description": "a travelling spell with effects",
      "parents": [ "wand_type" ],
      "fields": {
      }
    },
    {
      "class_name": "wand",
      "base_class_name": "map_tool",
      "class_description": "a magic thing that launches spells",
      "fields": {

      }
    },
    {
      "class_name": "spell",
      "base_class_name": "map_tool",
      "class_description": "a travelling spell with effects",
      "fields": {
      }
    },
    {
      "class_name": "stick_type",
      "base_class_name": "map_tool_type",
      "class_description": "general stick",
      "fields": {
        "reach": "double"
      }
    },
    {
      "class_name": "stick",
      "base_class_name": "map_tool",
      "class_description": "general stick",
      "parents": [ "stick_type" ],
      "fields": {
      }
    },
    {
      "class_name": "artifact_type",
      "base_class_name": "map_tool",
      "class_description": "general artifact",
      "fields": {
        "effect_type": [ "effect_type" ]
      }
    },
    {
      "class_name": "artifact",
      "base_class_name": "map_tool",
      "class_description": "general artifact",
      "fields": {
        "effect_type": [ "effect_type" ]
      }
    },
    {
      "class_name": "stick",
      "base_class_name": "map_tool",
      "class_description": "general stick",
      "parents": [ "stick_type" ],
      "fields": {
      }
    }
  ],
  "application": {
    "application_creator": "Todd Bandrowsky",
    "application_name": "Corona Video Game",
    "fields": {
      "description": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string.memo": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string": {
        "class_name": "edit_field",
        "box": "edit_field_box"
      }, 
      "datetime": {
        "class_name": "datetimepicker_field",
        "box": "edit_field_box"
      },
      "double": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "number": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "int64_t": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "boolean": {
        "class_name": "checkbox_field",
        "box": "edit_field_box"
      },
      "string.enumeration": {
        "class_name": "combobox_field",
        "box": "edit_field_box"
      }
    },
    "card_fields": [ "first_name", "last_name" ],
    "classes": {
      "game_session": "default"
    },
    "teams": { 
      "app_team": {
        "search_groups": [
          {
            "title": "people",
            "classes": [
              "person"
            ]
          }
        ],
        "new_objects": [ "person" ]
      }
    }
  }
}
