{
  "schema_name": "Revolution Arcade",
  "schema_description": "Revolution Arcade Application Schema",
  "schema_version": "1.1",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "datasets": [
    {
      "dataset_name": "App Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical, and the use of sys_team means it can go first",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "app_team",
          "team_description": "Local security for teams",
          "team_domain": "localhost.com",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "app_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ],
  "classes": [
    {
      "class_name": "activity",
      "base_class_name": "sys_object",
      "class_description": "An activity",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "First Name"
        },
        "image": "string"
      }
    },
    {
      "class_name": "mini_game",
      "base_class_name": "activity",
      "class_description": "A mini game in the system",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "First Name"
        },
        "image": "string",
        "maps": ["map"],
        "starting_map": "string",
        "sessions": ["session"]
      },
      "indexes": {
        "mini_game_name_index": {
          "index_keys": [ "name" ]
        }
      }
    },
    {
      "class_name": "essay",
      "base_class_name": "activity",
      "class_description": "An essay in the system",
      "full_text": [ "name", "description", "text" ],
      "fields": {
        "text": "string"
      }
    },
    {
      "class_name": "map",
      "base_class_name": "sys_object",
      "class_description": "a gaming map",
      "parents": [ "mini_game", "session" ],
      "fields": {
        "pieces": [ "piece" ],
        "friction": "vector",
        "gravity": "vector"
      }
    },
    {
      "class_name": "session",
      "base_class_name": "sys_object",
      "class_description": "a gaming session",
      "parents": [ "mini_game" ],
      "fields": {
        "maps": [ "map" ],
        "name": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "First Name"
        },
        "image": "string",
        "current_map": "string"
      }
    },
    {
      "class_name": "sprite",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "piece" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State",
          "max_length": 20
        },
        "order": {
          "field_type": "double",
          "label": "Order",
          "max_length": 20
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "size": "vector",
        "offset": "vector"
      }
    },
    {
      "class_name": "piece",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "mini_game" ],
      "fields": {
        "name": "string",
        "image_name": {
          "field_type": "string",
          "label": "Image asset name",
          "max_length": 200
        },
        "state": "string",
        "sprites": [ "sprite" ],
        "mass": "double",
        "full_hit_points": "double",
        "hit_points": "double",
        "inventory": {
          "field_type": "chest",
          "item_class": "item"
        }
      }
    },
    {
      "class_name": "item",
      "base_class_name": "piece",
      "class_description": "a gaming item",
      "fields": {
      }
    },
    {
      "class_name": "player",
      "base_class_name": "piece",
      "class_description": "a gaming player",
      "fields": {
        "input_device": "string"
      }
    },
    {
      "class_name": "loot_box",
      "base_class_name": "piece",
      "class_description": "a gaming loot box",
      "fields": {
        
      }
    },
    {
      "class_name": "npc",
      "base_class_name": "piece",
      "class_description": "a gaming NPC",
      "fields": {
        
      }
    },
    {
      "class_name": "wall",
      "base_class_name": "piece",
      "class_description": "a gaming wall",
      "fields": {
        "passable": "boolean"
      }
    },
    {
      "class_name": "door",
      "base_class_name": "piece",
      "class_description": "a gaming door",
      "fields": {
        "open": "boolean"
      }
    },
    {
      "class_name": "surface",
      "base_class_name": "piece",
      "class_description": "a gaming surface",
      "fields": {
        "mechanic": "string",
        "acceleration_multiplier": "double",
        "friction_multiplier": "double"
      }
    },
    {
      "class_name": "decoration",
      "base_class_name": "piece",
      "class_description": "a gaming decoration, like clouds",
      "fields": {
      }
    }
  ],
  "application": {
    "application_creator": "Todd Bandrowsky",
    "application_name": "Corona Demo Application",
    "fields": {
      "description": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string.memo": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string": {
        "class_name": "edit_field",
        "box": "edit_field_box"
      }, 
      "datetime": {
        "class_name": "datetimepicker_field",
        "box": "edit_field_box"
      },
      "double": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "number": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "int64_t": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "boolean": {
        "class_name": "checkbox_field",
        "box": "edit_field_box"
      },
      "string.enumeration": {
        "class_name": "combobox_field",
        "box": "edit_field_box"
      }
    },
    "card_fields": [ "first_name", "last_name" ],
    "classes": {
      "person": "default"
    },
    "teams": { 
      "app_team": {
        "search_groups": [
          {
            "title": "people",
            "classes": [
              "person"
            ]
          }
        ],
        "new_objects": [ "person" ]
      }
    }
  }
}
