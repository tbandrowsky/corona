{
  "schema_name": "Revolution Arcade",
  "schema_description": "Revolution Arcade Application Schema",
  "schema_version": "1.1",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "datasets": [
    {
      "dataset_name": "Revolution Arcade Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical, and the use of sys_team means it can go first",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "app_team",
          "team_description": "local player team",
          "team_domain": "localhost.com",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "sys_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ],
  "classes": [
    {
      "class_name": "game_base",
      "base_class_name": "sys_object",
      "class_description": "Base class of game for permissions",
      "fields": {
      }
    },
    {
      "class_name": "function_scheduler",
      "base_class_name": "game_base",
      "class_description": "A timer that invoked periodically",
      "fields": {
        "frequency_seconds": "double",
        "remaining_seconds": "double",
        "duration_seconds": "string",
        "enabled": "bool"
      }
    },
    {
      "class_name": "animation_scheduler",
      "base_class_name": "game_base",
      "class_description": "A timer that selects a frame",
      "fields": {
        "current_seconds": "double",
        "total_seconds": "double",
        "enabled": "bool",
        "current_index": "int64",
        "schedule": [ "double" ]
      }
    },
    {
      "class_name": "frame",
      "base_class_name": "game_base",
      "class_description": "a gaming piece",
      "parents": [ "animation" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State"
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "time_point": "double",
        "draw_rectangle": "rectangle",
        "fire_point": "vector",
        "sound": "audio"
      }
    },
    {
      "class_name": "bitmap_frame",
      "base_class_name": "frame",
      "class_description": "a gaming piece of an image",
      "fields": {
        "image": "bitmap"
      }
    },
    {
      "class_name": "vector_frame",
      "base_class_name": "frame",
      "class_description": "a gaming piece of an image",
      "fields": {
        "shape": "path",
        "fill": "brush",
        "stroke": "brush",
        "stroke_width": "double"
      }
    },
    {
      "class_name": "animation",
      "base_class_name": "game_base",
      "class_description": "a gaming piece",
      "parents": [ "piece" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State"
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "destination": "rectangle",
        "direction": "vector",
        "sound": "audio",
        "frames": [ "frame" ],
        "schedule": "animation_scheduler",
        "carry_point": "vector"
      }
    },
    {
      "class_name": "piece_type",
      "base_class_name": "game_base",
      "class_description": "a type of gaming piece",
      "fields": {
        "name": "string",
        "description": "string",
        "piece_class_name": "string",
        "animations": [ "animation" ],
        "mass": "double",
        "health": "double",
        "full_health": "double",
        "state": "string",
        "pieces": [ "piece" ],
        "defaults": "object",
        "inventory": {
          "field_type": "chest",
          "item_class": "piece_type"
        }
      },
      "indexes": {
        "piece_type_index": {
          "index_keys": [ "name" ]
        }
      }
    },
    {
      "class_name": "piece",
      "base_class_name": "game_base",
      "class_description": "a gaming piece",
      "parents": [ "map", "piece_type" ],
      "fields": {
        "name": "string",
        "mass": "double",
        "health": "double",
        "full_health": "double",
        "state": "string",
        "position": "vector",
        "size": "vector",
        "velocity": "vector",
        "facing": "vector",
        "owner": "->piece",
        "inventory": {
          "field_type": "chest",
          "item_class": "piece"
        }
      }
    },
    {
      "class_name": "piece_list",
      "base_class_name": "game_base",
      "class_description": "a list of gaming pieces",
      "parents": [ "map", "switcher" ],
      "fields": {
        "state": "string",
        "pieces ": [ "piece" ]
      }
    },
    {
      "class_name": "actor",
