{
  "schema_name": "Revolution Arcade",
  "schema_description": "Revolution Arcade Application Schema",
  "schema_version": "1.1",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "datasets": [
    {
      "dataset_name": "App Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical, and the use of sys_team means it can go first",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "app_team",
          "team_description": "Local security for teams",
          "team_domain": "localhost.com",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "app_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ],
  "classes": [
    {
      "class_name": "activity",
      "base_class_name": "sys_object",
      "class_description": "An activity",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "Description"
        },
        "image": "string"
      }
    },
    {
      "class_name": "game",
      "base_class_name": "activity",
      "class_description": "A game in the system",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "First Name"
        },
        "map": "map",
        "sessions": [ "session" ]
      },
      "indexes": {
        "game_name_index": {
          "index_keys": [ "name" ]
        }
      }
    },
    {
      "class_name": "essay",
      "base_class_name": "activity",
      "class_description": "An essay in the system",
      "full_text": [ "name", "description", "text" ],
      "fields": {
        "text": "string"
      }
    },
    {
      "class_name": "map",
      "base_class_name": "sys_object",
      "class_description": "a gaming map",
      "parents": [ "game", "session" ],
      "fields": {
        "image": "string",
        "pieces": [ "piece" ]
      }
    },
    {
      "class_name": "session",
      "base_class_name": "sys_object",
      "class_description": "a gaming session",
      "parents": [ "game" ],
      "fields": {
        "map": "map",
        "name": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 100
        },
        "state": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 20,
          "enumeration": [ "lobby", "active", "paused", "complete", "exit" ]
        },
        "description": {
          "field_type": "string",
          "label": "First Name"
        }
      }
    },
    {
      "class_name": "sprite",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "piece" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State"
        },
        "frame_index": {
          "field_type": "double",
          "label": "Frame Index"
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "offset": "vector",
        "size": "vector"
      }
    },
    {
      "class_name": "piece",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "map" ],
      "fields": {
        "name": "string",
        "image_name": {
          "field_type": "string",
          "label": "Image asset name",
          "max_length": 200
        },
        "position": "vector",
        "size": "vector",
        "velocity": "vector",
        "facing": "vector",
        "sprites": [ "sprite" ],
        "mass": "double",
        "full_hit_points": "double",
        "hit_points": "double",
        "inventory": {
          "field_type": "chest",
          "item_class": "piece"
        }
      }
    },
    {
      "class_name": "effect",
      "base_class_name": "piece",
      "class_description": "a gaming item",
      "fields": {
        "frequency_seconds": "double",
        "remaining_seconds": "double",
        "remaining_count": "double",
        "name": "string"
      }
    },
    {
      "class_name": "camera",
      "base_class_name": "piece",
      "class_description": "A camera in the system",
      "fields": {
        "fov": "double",
        "near_clip": "double",
        "far_clip": "double"
      }
    },
    {
      "class_name": "player_spawn",
      "base_class_name": "piece",
      "class_description": "A place to launch players",
      "fields": {
      }
    },
    {
      "class_name": "npc_spawn",
      "base_class_name": "piece",
      "class_description": "A place to launch npcs",
      "fields": {
        "spawn_classes": [ "string" ],
        "frequency_seconds": "double",
        "remaining_seconds": "double"
      }
    },
    {
      "class_name": "player",
      "base_class_name": "piece",
      "class_description": "a gaming player",
      "fields": {
        "input_device": "string",
        "state": {
          "field_type": "string",
          "label": "State",
          "selected_tool": "number",
          "enumeration": [
            "still",
            "moving",
            "shoot",
            "walk-up",
            "walk-down",
            "walk-right",
            "walk-left",
            "jump-up",
            "jump-down",
            "jump-right",
            "jump-left",
            "climb-up",
            "climb-down",
            "climb-right",
            "climb-left",
            "throw-up",
            "throw-down",
            "throw-right",
            "throw-left",
            "activate-up",
            "activate-down",
            "activate-right",
            "activate-left",
            "fire-up",
            "fire-down",
            "fire-right",
            "fire-left"
          ]
        }

      }
    },
    {
      "class_name": "loot_box",
      "base_class_name": "piece",
      "class_description": "a gaming loot box",
      "fields": {

      }
    },
    {
      "class_name": "loot_spot",
      "base_class_name": "piece",
      "class_description": "a gaming loot spot",
      "fields": {

      }
    },
    {
      "class_name": "switch",
      "base_class_name": "piece",
      "class_description": "a gaming switch",
      "fields": {

      }
    },
    {
      "class_name": "gun",
      "base_class_name": "piece",
      "class_description": "weapon for the shot",
      "fields": {
        "ammo_class": "string"
      }
    },
    {
      "class_name": "ammo",
      "base_class_name": "piece",
      "class_description": "consumable for the shot",
      "fields": {
        "shot_class": "string"
      }
    },
    {
      "class_name": "shot",
      "base_class_name": "piece",
      "class_description": "an effect of a weapon",
      "fields": {
        "effect_class": "string"
      }
    },
    {
      "class_name": "npc",
      "base_class_name": "piece",
      "class_description": "a gaming NPC",
      "fields": {
        "frequency_seconds": "double",
        "remaining_seconds": "double",
        "state": {
          "field_type": "string",
          "label": "State",
          "enumeration": [
            "still",
            "moving",
            "shoot",
            "walk-up",
            "walk-down",
            "walk-right",
            "walk-left",
            "jump-up",
            "jump-down",
            "jump-right",
            "jump-left",
            "climb-up",
            "climb-down",
            "climb-right",
            "climb-left",
            "throw-up",
            "throw-down",
            "throw-right",
            "throw-left",
            "activate-up",
            "activate-down",
            "activate-right",
            "activate-left",
            "fire-up",
            "fire-down",
            "fire-right",
            "fire-left"
          ]
        }

      }
    },
    {
      "class_name": "wall",
      "base_class_name": "piece",
      "class_description": "a gaming wall",
      "fields": {
        "passable": "boolean"
      }
    },
    {
      "class_name": "door",
      "base_class_name": "piece",
      "class_description": "a gaming door",
      "fields": {
        "open": "boolean"
      }
    },
    {
      "class_name": "surface",
      "base_class_name": "piece",
      "class_description": "a gaming surface",
      "fields": {
        "mechanic": "string",
        "acceleration_multiplier": "double",
        "friction_multiplier": "double"
      }
    },
    {
      "class_name": "decoration",
      "base_class_name": "piece",
      "class_description": "a gaming decoration, like clouds",
      "fields": {
      }
    },
    {
      "class_name": "shot",
      "base_class_name": "piece",
      "class_description": "a gaming shot",
      "fields": {
        "effect_class": "string",
        "frequency_seconds": "double",
        "remaining_seconds": "double"
      }
    }
  ],
  "application": {
    "application_creator": "Todd Bandrowsky",
    "application_name": "Corona Demo Application",
    "fields": {
      "description": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string.memo": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string": {
        "class_name": "edit_field",
        "box": "edit_field_box"
      }, 
      "datetime": {
        "class_name": "datetimepicker_field",
        "box": "edit_field_box"
      },
      "double": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "number": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "int64_t": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "boolean": {
        "class_name": "checkbox_field",
        "box": "edit_field_box"
      },
      "string.enumeration": {
        "class_name": "combobox_field",
        "box": "edit_field_box"
      }
    },
    "card_fields": [ "first_name", "last_name" ],
    "classes": {
      "person": "default"
    },
    "teams": { 
      "app_team": {
        "search_groups": [
          {
            "title": "people",
            "classes": [
              "person"
            ]
          }
        ],
        "new_objects": [ "person" ]
      }
    }
  }
}
