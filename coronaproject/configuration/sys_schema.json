{
  "schema_name": "Revolution Arcade",
  "schema_description": "Revolution Arcade Application Schema",
  "schema_version": "1.1",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "datasets": [
    {
      "dataset_name": "Revolution Arcade Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical, and the use of sys_team means it can go first",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "app_team",
          "team_description": "Local security for teams",
          "team_domain": "localhost.com",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "app_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ],
  "classes": [
    {
      "class_name": "activity",
      "base_class_name": "sys_object",
      "class_description": "An activity",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "Description"
        },
        "image": "bitmap"
      }
    },
    {
      "class_name": "world",
      "base_class_name": "activity",
      "class_description": "A world in the system",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "First Name"
        },
        "map": "map",
        "games": [ "game" ]
      },
      "indexes": {
        "game_name_index": {
          "index_keys": [ "name" ]
        }
      }
    },
    {
      "class_name": "essay",
      "base_class_name": "activity",
      "class_description": "An essay in the system",
      "full_text": [ "name", "description", "text" ],
      "fields": {
        "text": "string"
      }
    },
    {
      "class_name": "map",
      "base_class_name": "sys_object",
      "class_description": "a gaming map",
      "parents": [ "world", "session" ],
      "fields": {
        "image": "string",
        "pieces": [ "piece" ]
      }
    },
    {
      "class_name": "game",
      "base_class_name": "sys_object",
      "class_description": "a gaming session",
      "parents": [ "world" ],
      "fields": {
        "map": "map",
        "name": {
          "field_type": "string",
          "label": "Name",
          "max_length": 100
        },
        "state": {
          "field_type": "string",
          "label": "State",
          "max_length": 20,
          "enumeration": [ "lobby", "active", "paused", "complete", "exit" ]
        },
        "description": {
          "field_type": "string",
          "label": "Description"
        }
      }
    },
    {
      "class_name": "frame",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "animation" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State"
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "time_point": "double",
        "destination": "rectangle",
        "carry_point": "vector",
        "sound": "audio"
      }
    },
    {
      "class_name": "bitmap_frame",
      "base_class_name": "frame",
      "class_description": "a gaming piece of an image",
      "fields": {
        "image": "bitmap"
      }
    },
    {
      "class_name": "vector_frame",
      "base_class_name": "frame",
      "class_description": "a gaming piece of an image",
      "fields": {
        "shape": "path",
        "fill": "brush",
        "stroke": "brush",
        "stroke_width": "double"
      }
    },
    {
      "class_name": "animation",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "piece" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State"
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "destination": "rectangle",
        "direction": "vector",
        "sound": "audio",
        "frames": [ "frame" ]
      }
    },
    {
      "class_name": "piece",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "map" ],
      "fields": {
        "name": "string",
        "description": "string",
        "state": "string",
        "position": "vector",
        "size": "vector",
        "velocity": "vector",
        "facing": "vector",
        "animations": [ "animation" ],
        "mass": "double",
        "full_hit_points": "double",
        "inventory": {
          "field_type": "chest",
          "item_class": "item"
        }
      }
    },
    {
      "class_name": "actor",
      "base_class_name": "piece",
      "class_description": "a gaming player",
      "fields": {
        "selection": "selection"
      }
    },
    {
      "class_name": "player",
      "base_class_name": "actor",
      "class_description": "a gaming player",
      "fields": {
        "input_device": "string"
      }
    },
    {
      "class_name": "npc",
      "base_class_name": "actor",
      "class_description": "a gaming NPC",
      "fields": {

      }
    },
    {
      "class_name": "feature",
      "base_class_name": "piece",
      "class_description": "a static feature on a map"
    },
    {
      "class_name": "loot_box",
      "base_class_name": "feature",
      "class_description": "a gaming loot box",
      "fields": {

      }
    },
    {
      "class_name": "loot_spot",
      "base_class_name": "feature",
      "class_description": "a gaming loot spot",
      "fields": {

      }
    },
    {
      "class_name": "wall",
      "base_class_name": "feature",
      "class_description": "a gaming wall",
      "fields": {
        "passable": "boolean"
      }
    },
    {
      "class_name": "switcher",
      "base_class_name": "feature",
      "class_description": "a gaming switch",
      "fields": {

      }
    },
    {
      "class_name": "door",
      "base_class_name": "feature",
      "class_description": "a gaming door",
      "fields": {
        "open": "boolean"
      }
    },
    {
      "class_name": "surface",
      "base_class_name": "feature",
      "class_description": "a gaming surface",
      "fields": {
        "mechanic": "string",
        "acceleration_multiplier": "double",
        "friction_multiplier": "double"
      }
    },
    {
      "class_name": "decoration",
      "base_class_name": "feature",
      "class_description": "a gaming decoration, like clouds",
      "fields": {
      }
    },
    {
      "class_name": "light",
      "base_class_name": "feature",
      "class_description": "A light",
      "fields": {
        "lumens": "double",
        "color": "vector"
      }
    },
    {
      "class_name": "spot_light",
      "base_class_name": "feature",
      "class_description": "A light",
      "fields": {
        "direction": "vector",
        "fov": "double"
      }
    },
    {
      "class_name": "globe_light",
      "base_class_name": "feature",
      "class_description": "A light",
      "fields": {
        "radius": "double"
      }
    },
    {
      "class_name": "camera",
      "base_class_name": "feature",
      "class_description": "A camera in the system",
      "fields": {
        "fov": "double",
        "near_clip": "double",
        "far_clip": "double"
      }
    },
    {
      "class_name": "effect",
      "base_class_name": "piece",
      "class_description": "a gaming item",
      "parents": [ "shot", "spell", "stick", "artifact" ],
      "fields": {
        "frequency_seconds": "double",
        "remaining_seconds": "double",
        "remaining_count": "double",
        "name": "string"
      }
    },
    {
      "class_name": "delivery",
      "base_class_name": "piece",
      "class_description": "general consumable thing",
      "fields": {
        "effect": "effect"
      }
    },
    {
      "class_name": "carryable",
      "base_class_name": "piece",
      "class_description": "general carryable thing",
      "fields": {
      }
    },
    {
      "class_name": "consumable",
      "base_class_name": "carryable",
      "class_description": "general consumable thing",
      "fields": {

      }
    },
    {
      "class_name": "tool",
      "base_class_name": "carryable",
      "class_description": "general activatable thing",
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "consumable"
        }
      }
    },
    {
      "class_name": "consumable",
      "base_class_name": "carryable",
      "class_description": "general consumable thing",
      "fields": {

      }
    },
    {
      "class_name": "firearm",
      "base_class_name": "tool",
      "class_description": "weapon for the shot",
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "magazine"
        }
      }
    },
    {
      "class_name": "magazine",
      "base_class_name": "carryable",
      "class_description": "a magazine for the firearm",
      "parents": [ "firearm" ],
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "ammunition"
        }
      }
    },
    {
      "class_name": "ammunition",
      "base_class_name": "carryable",
      "class_description": "ammo for the firearm",
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "shot"
        }
      }
    },
    {
      "class_name": "shot",
      "base_class_name": "piece",
      "class_description": "an effect of a weapon",
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "effect"
        }
      }
    },
    {
      "class_name": "wand",
      "base_class_name": "tool",
      "class_description": "a magic thing that launches spells",
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "spell"
        }
      }
    },
    {
      "class_name": "spell",
      "base_class_name": "carryable",
      "class_description": "a travelling spell with effects",
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "effect"
        }
      }
    },
    {
      "class_name": "stick",
      "base_class_name": "tool",
      "class_description": "general stick",
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "effect"
        }
      }
    },
    {
      "class_name": "artifact",
      "base_class_name": "tool",
      "class_description": "general artifact",
      "fields": {
        "inventory": {
          "field_type": "chest",
          "item_class": "effect"
        }
      }
    }
  ],
  "application": {
    "application_creator": "Todd Bandrowsky",
    "application_name": "Corona Video Game",
    "fields": {
      "description": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string.memo": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string": {
        "class_name": "edit_field",
        "box": "edit_field_box"
      }, 
      "datetime": {
        "class_name": "datetimepicker_field",
        "box": "edit_field_box"
      },
      "double": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "number": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "int64_t": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "boolean": {
        "class_name": "checkbox_field",
        "box": "edit_field_box"
      },
      "string.enumeration": {
        "class_name": "combobox_field",
        "box": "edit_field_box"
      }
    },
    "card_fields": [ "first_name", "last_name" ],
    "classes": {
      "game_session": "default"
    },
    "teams": { 
      "app_team": {
        "search_groups": [
          {
            "title": "people",
            "classes": [
              "person"
            ]
          }
        ],
        "new_objects": [ "person" ]
      }
    }
  }
}
