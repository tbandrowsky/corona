    {
      "class_name": "adventure",
      "base_class_name": "game_base",
      "class_description": "playing a game is having an adventure",
      "parents": [ "game" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "Name",
          "max_length": 100
        },
        "team_name":  {
          "field_type": "string",
          "label": "Team Name",
          "max_length": 100
        },
        "description": {
          "field_type": "string",
          "label": "Description"
        },
        "stage": "set",
        "state": {
          "field_type": "string",
          "label": "State",
          "max_length": 20,
          "enumeration": [ "lobby", "active", "paused", "complete", "exit" ]
        }
      }
    },
    {
      "class_name": "game",
      "base_class_name": "activity",
      "class_description": "A world with rules one may adventure in",
      "full_text": [ "name", "description", "image" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "Name",
          "max_length": 100
        },
