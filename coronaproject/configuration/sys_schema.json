{
  "schema_name": "Revolution Arcade",
  "schema_description": "Revolution Arcade.",
  "schema_version": "1.1",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "datasets": [
    {
      "dataset_name": "App Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical, and the use of sys_team means it can go first",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "app_team",
          "team_description": "Local security for teams",
          "team_domain": "localhost.com",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "app_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ],
  "classes": [
    {
      "class_name": "mini_game",
      "base_class_name": "sys_object",
      "class_description": "A mini game in the system",
      "full_text": [ "name", "description", "genre", "platform" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "First Name",
          "max_length": 20
        },
        "map": "map",
        "sessions": "[session]"
      }
    },
    {
      "class_name": "session",
      "base_class_name": "sys_object",
      "class_description": "a gaming session",
      "parents": [ "mini_game" ],
      "fields": {
        "players": "[player]"
      }
    },
    {
      "class_name": "player",
      "base_class_name": "sys_object",
      "class_description": "a gaming player",
      "parents": [ "mini_game" ],
      "fields": {
        "players": "[player]"
      }
    },
    {
      "class_name": "image_section",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "piece" ],
      "fields": {
        "state": {
          "field_type": "string",
          "label": "State",
          "max_length": 20
        },
        "order": {
          "field_type": "string",
          "label": "Order",
          "max_length": 20
        },
        "duration": {
          "field_type": "double",
          "label": "Duration"
        },
        "width": {
          "field_type": "double",
          "label": "Width"
        },
        "height": {
          "field_type": "double",
          "label": "Height"
        },
        "x": {
          "field_type": "double",
          "label": "X"
        },
        "y": {
          "field_type": "double",
          "label": "Y"
        }
      }
    },
    {
      "class_name": "piece",
      "base_class_name": "sys_object",
      "class_description": "a gaming piece",
      "parents": [ "mini_game" ],
      "fields": {
        "name": "string",
        "image": {
          "field_type": "string",
          "label": "Image asset name",
          "max_length": 200
        },
        "state": "string",
        "image_sections": "[image_section]",
        "dx": "double",
        "dy": "double",
        "ax": "double",
        "ay": "double",
        "cx": "double",
        "cy": "double",
        "cz": "double"
      }
    },
    {
      "class_name": "item",
      "base_class_name": "piece",
      "class_description": "a gaming item",
      "fields": {
        "name": "string",
        "image": {
          "field_type": "string",
          "label": "Image asset name",
          "max_length": 200
        },
        "state": "string",
        "image_sections": "[image_section]",
        "dx": "double",
        "dy": "double",
        "ax": "double",
        "ay": "double",
        "cx": "double",
        "cy": "double",
        "cz": "double"
      }
    },
    {
      "class_name": "player",
      "base_class_name": "piece",
      "class_description": "a gaming player",
      "fields": {
        "input_device": "string",
        "full_hit_points": "double",
        "hit_points": "double",
        "inventory": {
          "field_type": "[chest]"
        }
      }
    },
    {
      "class_name": "npc",
      "base_class_name": "piece",
      "class_description": "a gaming NPC",
      "fields": {
        "input_device": "string",
        "full_hit_points": "double",
        "hit_points": "double"
      }
    },
    {
      "class_name": "wall",
      "base_class_name": "piece",
      "class_description": "a gaming wall",
      "fields": {
        "full_hit_points": "double",
        "hit_points": "double"
      }
    },
    {
      "class_name": "door",
      "base_class_name": "piece",
      "class_description": "a gaming door",
      "fields": {
        "full_hit_points": "double",
        "hit_points": "double"
      }
    },
    {
      "class_name": "liquid",
      "base_class_name": "piece",
      "class_description": "a gaming liquid",
      "fields": {
        "full_hit_points": "double",
        "hit_points": "double"
      }
    },
    {
      "class_name": "ice",
      "base_class_name": "piece",
      "class_description": "a gaming ice",
      "fields": {
        "full_hit_points": "double",
        "hit_points": "double"
      }
    },
    {
      "class_name": "decoration",
      "base_class_name": "piece",
      "class_description": "a gaming decoration, like clouds",
      "fields": {
        "full_hit_points": "double",
        "hit_points": "double"
      }
    }
  ],
  "application": {
    "application_creator": "Todd Bandrowsky",
    "application_name": "Corona Demo Application",
    "fields": {
      "description": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string.memo": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string": {
        "class_name": "edit_field",
        "box": "edit_field_box"
      },
      "datetime": {
        "class_name": "datetimepicker_field",
        "box": "edit_field_box"
      },
      "double": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "number": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "int64_t": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "boolean": {
        "class_name": "checkbox_field",
        "box": "edit_field_box"
      },
      "string.enumeration": {
        "class_name": "combobox_field",
        "box": "edit_field_box"
      }
    },
    "card_fields": [ "first_name", "last_name" ],
    "classes": {
      "person": "default"
    },
    "teams": {
      "app_team": {
        "search_groups": [
          {
            "title": "people",
            "classes": [
              "person"
            ]
          }
        ],
        "new_objects": [ "person" ]
      }
    }
  }
}
