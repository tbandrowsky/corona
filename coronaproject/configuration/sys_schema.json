{
  "schema_name": "Sample Application",
  "schema_description": "Sample Corona Application.",
  "schema_version": "1.1",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "classes": [
    {
      "class_name": "person",
      "base_class_name": "sys_object",
      "class_description": "A person in the system",
      "full_text": [ "first_name", "last_name", "middle_name", "description" ],
      "fields": {
        "first_name": {
          "field_type": "string",
          "label": "First Name",
          "required": true,
          "max_length": 100
        },
        "last_name": {
          "field_type": "string",
          "label": "Last Name",
          "required": true,
          "max_length": 100
        },
        "middle_name": {
          "field_type": "string",
          "label": "Middle Name",
          "max_length": 10
        },
        "description": {
          "field_type": "string",
          "label": "Description",
          "max_length": 1000
        }
      }
    }
  ],
  "users": [

  ],
  "application": {
    "fields": {
      "description": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string.memo": {
        "class_name": "memo_field",
        "box": "memo_field_box"
      },
      "string": {
        "class_name": "edit_field",
        "box": "edit_field_box"
      },
      "datetime": {
        "class_name": "datetimepicker_field",
        "box": "edit_field_box"
      },
      "double": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "number": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "int64_t": {
        "class_name": "number_field",
        "box": "edit_field_box"
      },
      "boolean": {
        "class_name": "checkbox_field",
        "box": "edit_field_box"
      },
      "string.enumeration": {
        "class_name": "combobox_field",
        "box": "edit_field_box"
      }
    },
    "card_fields": [ "first_name", "last_name" ],
    "classes": {
      "person":"default"
    },
    "teams": {
      "app_team": {
        "search_groups": [
          {
            "title": "people",
            "classes": [
              "person"
            ]
          }
        ],
        "new_objects": [ "person" ]
      }
    }
  },
  "datasets": [
    {
      "dataset_name": "App Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "app_team",
          "team_description": "Local security for teams",
          "team_domain": "ANY",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "app_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ]
}
