{
  "class_name": "page",
  "page_name": "page_client_check_card",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\check.png",
      "$card_contents": [
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "check_number",
          "text_style": {
            "font_size": 16,
            "bold": true
          }
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "amount"
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "bank_account_number"
        }
      ]
    }
  }
}
