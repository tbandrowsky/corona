{
  "class_name": "page",
  "page_name": "page_client_rate_card",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\client_rate.png",
      "$card_height": "75 pixels",
      "$card_contents": [
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "rate_name",
          "text_style": {
            "font_size": 16,
            "bold": true
          }
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "activity_class_name"
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "hourly_rate"
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "flat_rate"
        }
      ]
    }
  }
}
