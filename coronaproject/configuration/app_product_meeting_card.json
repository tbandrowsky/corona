{
  "class_name": "page",
  "page_name": "card_product_meeting",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\meeting.png",
      "$card_height": "75 pixels",
      "$details_contents": [
        {
          "class_name": "paragraph",
          "json_field_name": "status",
          "text": "{status}",
          "box": "card_text_box"
        },
        {
          "class_name": "paragraph",
          "json_field_name": "task_date",
          "text": "{task_date}",
          "box": "card_text_box"
        }
      ]
    }
  }
}
