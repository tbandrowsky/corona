{
  "class_name": "page",
  "page_name": "card_product_person",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\appliance.png",
      "$card_height": "75 pixels",
      "$card_contents": [
        {
          "class_name": "paragraph",
          "json_field_name": "last_name",
          "text": "{first_name} {last_name}",
          "box": "card_text_box"
        }
      ]
    }
  }
}
