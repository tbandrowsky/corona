{
  "schema_name": "My Application",
  "schema_description": "Schema for Sample SDLC Application.",
  "schema_version": "1.0",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "classes": [
    {
      "class_name": "app_object",
      "base_class_name": "sys_object",
      "class_description": "A root object of searchable things",
      "fields": {
        "description": {
          "field_type": "string",
          "label": "Description"
        },
        "notes": "[app_note]"
      }
    },
    {
      "class_name": "app_note",
      "base_class_name": "app_object",
      "class_description": "A note that can be placed on an object",
      "parents": [ "app_object" ],
      "full_text": [ "note_text" ],
      "fields": {
        "note_text": {
          "field_type": "string",
          "label": "Text"
        }
      }
    },
    {
      "class_name": "dated_item",
      "class_description": "An appointment to meet someone",
      "base_class_name": "app_object",
      "class_color": "#af9d66",
      "full_text": [ "text" ],
      "fields": {
        "item_date": {
          "field_type": "datetime",
          "label": "Date"
        }
      }
    },
    {
      "class_name": "meeting",
      "class_description": "An appointment to meet someone",
      "base_class_name": "dated_item",
      "class_color": "#af9d66",
      "full_text": [ "text" ],
      "fields": {
        "with": {
          "field_type": "string",
          "label": "With"
        },
        "duration": {
          "field_type": "string",
          "label": "Length"
        },
        "meeting_time": "string",
        "where": {
          "field_type": "string",
          "label": "Where"
        }
      }
    },
    {
      "class_name": "product",
      "base_class_name": "app_object",
      "class_description": "A general job to do",
      "full_text": [ "story" ],
      "fields": {
        "official_name": "string",
        "common_name": "string",
        "public_name": "string",
        "projects": "[project]",
        "assets": "[asset]",
        "milestones": "[milestone]"
      }
    },
    {
      "class_name": "request",
      "base_class_name": "app_object",
      "class_description": "A request for a product",
      "parents": [ "product" ],
      "fields": {
        "details": {
          "field_type": "string",
          "label": "Details"
        }
      }
    },
    {
      "class_name": "project",
      "base_class_name": "dated_item",
      "class_description": "A general job to do",
      "full_text": [ "description", "status" ],
      "parents": [ "product" ],
      "fields": {
        "status": {
          "field_type": "string",
          "label": "Status"
        },
        "charter": {
          "field_type": "string",
          "label": "Charter"
        },
        "tasks": "[task]",
        "milestones": "[milestone]"
      }
    },
    {
      "class_name": "milestone",
      "class_description": "A checkpoint and progress marker",
      "base_class_name": "dated_item",
      "class_color": "#af9d66",
      "full_text": [ "text" ],
      "parents": [ "product", "project" ],
      "fields": {
        "status": {
          "field_type": "string",
          "label": "Status"
        }
      }
    },
    {
      "class_name": "asset",
      "base_class_name": "app_object",
      "class_description": "An asset used on a project",
      "parents": [ "product" ],
      "fields": {
      }
    },
    {
      "class_name": "person",
      "base_class_name": "asset",
      "class_description": "A person",
      "fields": {
        "first_name": "string",
        "last_name": "string",
        "title": "string",
        "skills": "string",
        "username": "string",
        "activities": "[activity]"
      }
    },
    {
      "class_name": "server",
      "base_class_name": "asset",
      "class_description": "A server",
      "fields": {
        "url": "string",
        "unc": "string",
        "cpu": "string",
        "cores": "string",
        "memory": "string"
      }
    },
    {
      "class_name": "reference",
      "base_class_name": "asset",
      "class_description": "A reference or resource",
      "fields": {
        "url": "string",
        "isbn": "string",
        "synopsis": "string"
      }
    },
    {
      "class_name": "license",
      "base_class_name": "asset",
      "class_description": "A license",
      "fields": {
        "product_name": "string",
        "url": "string",
        "license_key": "string"
      }
    },
    {
      "class_name": "environment",
      "base_class_name": "asset",
      "class_description": "An environment for test",
      "full_text": [ "status" ],
      "parents": [ "product" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "Name"
        },
        "url": {
          "field_type": "string",
          "label": "URL"
        },
        "status": {
          "field_type": "string",
          "label": "Status"
        }
      }
    },
    {
      "class_name": "task",
      "base_class_name": "dated_item",
      "class_description": "A general job to do",
      "parents": [ "product", "project", "person" ],
      "full_text": [ "description", "status" ],
      "fields": {
        "status": {
          "field_type": "string",
          "label": "Status"
        },
        "activities": "[activity]"
      }
    },
    {
      "class_name": "activity",
      "base_class_name": "dated_item",
      "class_description": "An activity",
      "parents": [ "task", "person" ],
      "fields": {
        "hours": {
          "field_type": "double",
          "label": "Hours"
        }
      }
    },
    {
      "class_name": "requirements",
      "base_class_name": "activity",
      "class_description": "Defining the desired outcome",
      "fields": {
      }
    },
    {
      "class_name": "plan",
      "base_class_name": "activity",
      "class_description": "Planning for achieving the outcome",
      "fields": {
      }
    },
    {
      "class_name": "build",
      "base_class_name": "activity",
      "class_description": "Building and testing",
      "fields": {
      }
    },
    {
      "class_name": "delivery",
      "base_class_name": "activity",
      "class_description": "Delivering the final product",
      "fields": {
      }
    },
    {
      "class_name": "documentation",
      "base_class_name": "activity",
      "class_description": "Creating and maintaining documentation",
      "fields": {
      }
    },
    {
      "class_name": "support",
      "base_class_name": "activity",
      "class_description": "Providing support and assistance",
      "fields": {
      }
    },
    {
      "class_name": "quickchange",
      "base_class_name": "activity",
      "class_description": "Making a quick change to a system for bugs",
      "fields": {
      }
    },
    {
      "class_name": "training",
      "base_class_name": "activity",
      "class_description": "Training and education",
      "fields": {
      }
    }
  ],
  "users": [

  ],
  "datasets": [
    {
      "dataset_name": "App Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "App Team",
          "team_description": "Local security for teams",
          "team_domain": "ANY",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "app_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ]
}
