    {
      "class_name": "client_invoice",
      "base_class_name": "client_transaction",
      "class_description": "A client invoice",
      "fields": {
        "activity": "[activity]",
        "transaction": "[client_transaction]",

        "post": {
          "field_type": "query",
          "run_on_demand": true,
          "query": {
            "from": [
              {
                "class_name": "rate",
                "filter": {
                  "client": "$this.client"
                }
              }
            ],
            "stages": [
              {
                "name": "charge",
                "class_name": "select_many",
                "source": "$this",
                "path": "activity"
              },
              {
                "name": "charge_rate",
                "class_name": "join",
                "source1": "charge",
                "source2": "rate",
                "resultname1": "charge",
                "resultname2": "rate",
                "keys1": "class_name",
                "keys2": "activity_class_name"
              },
              {
                "name": "debits",
                "class_name": "project",
                "source": "charge_rate",
                "projection": {
                  "class_name": "general_ledger_entry",
                  "account_number": "client.receivables_account_number",
                  "debit": "charge.hours * rate.hourly_rate + rate.flat_rate",
                  "credit": 0.0,
                  "reference": "this.object_id",
                  "reference_class": "client_invoice"
                }
              },
              {
                "name": "credits",
                "class_name": "project",
                "source": "charge_rate",
                "projection": {
                  "class_name": "general_ledger_entry",
                  "account_number": "rate.credit_account_number",
                  "debit": 0.0,
                  "credit": "charge.hours * rate.hourly_rate + rate.flat_rate",
                  "reference": "this.object_id",
                  "reference_class": "client_invoice"
                }
              },
              {
                "class_name": "put",
                "source": "credits"
              },
              {
                "class_name": "put",
                "source": "debits"
              },
              {
                "class_name": "result",
                "source": "debits"
              }
            ]
          }
        }
      }
    },
