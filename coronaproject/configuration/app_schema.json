{
  "schema_name": "My Application",
  "schema_description": "Schema for Sample SDLC Application.",
  "schema_version": "1.0",
  "schema_authors": [
    "TJ Bandrowsky"
  ],
  "classes": [
    {
      "class_name": "app_object",
      "base_class_name": "sys_object",
      "class_description": "A root object of searchable things",
      "full_text": [ "description" ],
      "fields": {
        "description": {
          "field_type": "string",
          "label": "Description"
        },
        "notes": "[app_note]"
      }
    },
    {
      "class_name": "app_note",
      "base_class_name": "app_object",
      "class_description": "A note that can be placed on an object",
      "parents": [ "app_object" ],
      "full_text": [ "note_text" ],
      "fields": {
        "note_text": {
          "field_type": "string",
          "label": "Text"
        }
      }
    },
    {
      "class_name": "dated_item",
      "class_description": "An appointment to meet someone",
      "base_class_name": "app_object",
      "class_color": "#af9d66",
      "fields": {
        "item_date": {
          "field_type": "datetime",
          "label": "Date"
        }
      },
      "indexes": {
        "idx_item_date": {
          "index_keys": [ "item_date" ]
        }
      }
    },
    {
      "class_name": "general_ledger_account",
      "base_class_name": "app_object",
      "class_description": "General ledger account",
      "full_text": [ "account_number", "account_name", "account_type", "balance" ],
      "fields": {
        "account_number": {
          "field_type": "string",
          "label": "Account Number"
        },
        "account_name": {
          "field_type": "string",
          "label": "Account Name"
        },
        "account_type": {
          "field_type": "string",
          "label": "Account Type",
          "enumeration": [ "Asset", "Liability", "Equity", "Revenue", "Expense" ]
        },
        "balance": {
          "field_type": "double",
          "label": "Balance"
        },
        "transactions": "[transaction_detail]"
      },
      "indexes": {
        "idx_gl_account_number": {
          "index_keys": [ "account_number" ]
        }
      }
    },
    {
      "class_name": "general_ledger_period",
      "base_class_name": "app_object",
      "class_description": "A general ledger period",
      "full_text": [ "period_name", "start_date", "end_date" ],
      "fields": {
        "period_name": {
          "field_type": "string",
          "label": "Period Name"
        },
        "start_date": {
          "field_type": "datetime",
          "label": "Start Date"
        },
        "end_date": {
          "field_type": "datetime",
          "label": "End Date"
        },
        "posts": "[general_ledger_post]"
      }
    },
    {
      "class_name": "transaction",
      "base_class_name": "dated_item",
      "class_description": "A transaction in the general ledger",
      "full_text": [ "amount" ],
      "fields": {
        "accounts": "[transaction_account]",
        "posts": "[general_ledger_post]"
      }
    },
    {
      "class_name": "invoice",
      "base_class_name": "transaction",
      "class_description": "An invoice",
      "fields": {
      }
    },
    {
      "class_name": "general_ledger_post",
      "base_class_name": "app_object",
      "class_description": "A general ledger post",
      "parents": [ "general_ledger_period", "transaction" ],
      "full_text": [],
      "fields": {
      }
    },
    {
      "class_name": "transaction_account",
      "base_class_name": "app_object",
      "class_description": "A transaction detail",
      "full_text": [ "amount" ],
      "parents": [ "general_ledger_account" ],
      "fields": {
        "amount": {
          "field_type": "double",
          "label": "Amount"
        }
      }
    },
    {
      "class_name": "person",
      "base_class_name": "app_object",
      "class_description": "A person",
      "parents": [ "client", "product", "meeting_person" ],
      "fields": {
        "first_name": "string",
        "last_name": "string",
        "email": "string",
        "phone": "string",
        "fax": "string",
        "facebook": "string",
        "linkedin": "string",
        "twitter": "string",
        "discord": "string",
        "title": "string",
        "skills": "string",
        "username": "string",
        "activities": "[activity]"
      }
    },
    {
      "class_name": "meeting_person",
      "base_class_name": "app_object",
      "class_description": "A person",
      "parents": [ "meeting", "person" ],
      "fields": {
      }
    },
    {
      "class_name": "meeting",
      "class_description": "An appointment to meet someone",
      "base_class_name": "dated_item",
      "class_color": "#af9d66",
      "full_text": [ "title", "agenda", "with", "when", "where" ],
      "fields": {
        "title": {
          "field_type": "string",
          "label": "Title"
        },
        "attendees": "[meeting_person]",
        "agenda": {
          "field_type": "string",
          "label": "Agenda"
        },
        "with": {
          "field_type": "string",
          "label": "With"
        },
        "duration": {
          "field_type": "string",
          "label": "Length"
        },
        "meeting_time": "string",
        "where": {
          "field_type": "string",
          "label": "Where"
        }
      }
    },
    {
      "class_name": "client",
      "base_class_name": "app_object",
      "class_description": "A client",
      "full_text": [ "company_name", "street1", "street2", "city", "state", "zip", "domain_name" ],
      "fields": {
        "company_name": "string",
        "street1": "string",
        "street2": "string",
        "city": "string",
        "state": "string",
        "zip": "string",
        "domain_name": "string",
        "website": "string",
        "people": "[person]",
        "products": "[product]"
      }
    },
    {
      "class_name": "product",
      "base_class_name": "app_object",
      "class_description": "A custom product for a client",
      "full_text": [ "common_name", "charter_name", "public_name" ],
      "fields": {
        "common_name": "string",
        "charter_name": "string",
        "public_name": "string",
        "projects": "[project]",
        "assets": "[asset]",
        "people": "[person]",
        "milestones": "[milestone]"
      }
    },
    {
      "class_name": "request",
      "base_class_name": "app_object",
      "class_description": "A request for a product",
      "full_text": [ "title" ],
      "parents": [ "client", "person" ],
      "fields": {
        "title": {
          "field_type": "string",
          "label": "Title"
        }
      }
    },
    {
      "class_name": "project",
      "base_class_name": "dated_item",
      "class_description": "A general job to do",
      "full_text": [ "description", "status" ],
      "parents": [ "product" ],
      "fields": {
        "title": {
          "field_type": "string",
          "label": "Title"
        },
        "charter": {
          "field_type": "string",
          "label": "Charter"
        },
        "status": {
          "field_type": "string",
          "label": "Status",
          "enumeration": [ "Not Started", "In Progress", "Completed", "On Hold", "Cancelled" ]
        },
        "tasks": "[task]",
        "milestones": "[milestone]"
      }
    },
    {
      "class_name": "milestone",
      "class_description": "A checkpoint and progress marker",
      "base_class_name": "dated_item",
      "class_color": "#af9d66",
      "full_text": [ "title", "assessment", "assessment_reason" ],
      "parents": [ "product", "project" ],
      "fields": {
        "title": {
          "field_type": "string",
          "label": "Title"
        },
        "assessment": {
          "field_type": "string",
          "label": "Status",
          "enumeration": [ "Green", "Yellow", "Red" ]
        },
        "assessment_reason": {
          "field_type": "string",
          "label": "Assessment Reason"
        }
      }
    },
    {
      "class_name": "asset",
      "base_class_name": "app_object",
      "class_description": "An asset used on a project",
      "parents": [ "product" ],
      "fields": {
      }
    },
    {
      "class_name": "server",
      "base_class_name": "asset",
      "class_description": "A server",
      "full_text": [ "name", "url", "unc", "cpu", "cores", "memory", "storage" ],
      "fields": {
        "name": "string",
        "url": "string",
        "unc": "string",
        "cpu": "string",
        "cores": "string",
        "memory": "string",
        "storage": "string"
      }
    },
    {
      "class_name": "environment_server",
      "base_class_name": "app_object",
      "class_description": "A server in an environment",
      "parents": [ "environment", "server" ],
      "fields": {
      }
    },

    {
      "class_name": "reference",
      "base_class_name": "asset",
      "class_description": "A reference or resource",
      "full_text": [ "title", "url", "isbn", "synopsis" ],
      "fields": {
        "title": "string",
        "url": "string",
        "isbn": "string",
        "synopsis": "string"
      }
    },
    {
      "class_name": "license",
      "base_class_name": "asset",
      "class_description": "A license",
      "full_text": [ "product_name", "product_version", "license_terms", "url", "license_key" ],
      "fields": {
        "product_name": "string",
        "product_version": "string",
        "license_terms": "string",
        "url": "string",
        "license_key": "string"
      }
    },
    {
      "class_name": "environment",
      "base_class_name": "asset",
      "class_description": "An environment for test",
      "full_text": [ "name", "url" ],
      "parents": [ "product" ],
      "fields": {
        "name": {
          "field_type": "string",
          "label": "Name"
        },
        "url": {
          "field_type": "string",
          "label": "URL"
        },
        "servers": "[environment_server]"
      }
    },
    {
      "class_name": "task",
      "base_class_name": "dated_item",
      "class_description": "A general job to do",
      "parents": [ "project" ],
      "full_text": [ "description", "status" ],
      "fields": {
        "title": {
          "field_type": "string",
          "label": "Title"
        },
        "status": {
          "field_type": "string",
          "label": "Status"
        },
        "activities": "[activity]"
      }
    },
    {
      "class_name": "activity",
      "base_class_name": "dated_item",
      "class_description": "An activity",
      "parents": [ "task", "person" ],
      "fields": {
        "hours": {
          "field_type": "double",
          "label": "Hours"
        }
      }
    },
    {
      "class_name": "requirements",
      "base_class_name": "activity",
      "class_description": "Defining the desired outcome",
      "fields": {
      }
    },
    {
      "class_name": "plan",
      "base_class_name": "activity",
      "class_description": "Planning for achieving the outcome",
      "fields": {
      }
    },
    {
      "class_name": "build",
      "base_class_name": "activity",
      "class_description": "Building and testing",
      "fields": {
      }
    },
    {
      "class_name": "delivery",
      "base_class_name": "activity",
      "class_description": "Delivering the final product",
      "fields": {
      }
    },
    {
      "class_name": "documentation",
      "base_class_name": "activity",
      "class_description": "Creating and maintaining documentation",
      "fields": {
      }
    },
    {
      "class_name": "support",
      "base_class_name": "activity",
      "class_description": "Providing support and assistance",
      "fields": {
      }
    },
    {
      "class_name": "quickchange",
      "base_class_name": "activity",
      "class_description": "Making a quick change to a system for bugs",
      "fields": {
      }
    },
    {
      "class_name": "training",
      "base_class_name": "activity",
      "class_description": "Training and education",
      "fields": {
      }
    }
  ],
  "users": [

  ],
  "datasets": [
    {
      "dataset_name": "App Teams",
      "dataset_description": "Teams and their default memberships",
      "dataset_version": "1.1",
      "dataset_author": "Todd Bandrowsky",
      "dataset_source": "This is canonical",
      "objects": [
        {
          "class_name": "sys_team",
          "team_name": "App Team",
          "team_description": "Local security for teams",
          "team_domain": "ANY",
          "inventory_classes": [],
          "allowed_teams": [],
          "permissions": [
            {
              "class_name": "sys_grant",
              "grant_classes": [ "app_object" ],
              "get": "any",
              "put": "any",
              "delete": "any",
              "alter": "any"
            }
          ]
        }
      ]
    }
  ]
}
