{
  "class_name": "page",
  "page_name": "page_general_ledger_period_card",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\period.png",
      "$card_contents": [
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "period_name",
          "text_style": {
            "font_size": 16,
            "bold": true
          }
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "start_date"
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "end_date"
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "closing_date"
        }
      ]
    }
  }
}
