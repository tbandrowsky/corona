{
  "class_name": "page",
  "page_name": "card_product_reference",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\server.png",
      "$card_height": "75 pixels",
      "$card_contents": [
        {
          "class_name": "paragraph",
          "json_field_name": "description",
          "text": "{description}",
          "box": "card_text_box"
        },
        {
          "class_name": "paragraph",
          "json_field_name": "model_number",
          "text": "{cpu}/{cores}",
          "box": "card_text_box"
        }
      ]
    }
  }
}
