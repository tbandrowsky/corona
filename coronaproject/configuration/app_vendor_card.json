{
  "class_name": "page",
  "page_name": "page_vendor_card",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\vendor.png",
      "$card_contents": [
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "company_name",
          "text_style": {
            "font_size": 16,
            "bold": true
          }
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "account_number"
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "city"
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "balance"
        }
      ]
    }
  }
}
