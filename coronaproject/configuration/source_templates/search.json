{
  "class_name": "page",
  "page_name": "page_search",
  "default": true,
  "children": [
    {
      "class_name": "column",
      "box": "full_container",
      "children": [
        {
          "class_name": "placeholder",
          "name": "search_placeholder",
          "text": "",
          "box": {
            "width": "1.0 container",
            "height": "16.0 pixels"
          }
        },
        {
          "class_name": "row",
          "name": "search_top_bar",
          "box": {
            "width": "1.0 container",
            "height": "40 pixels"
          },
          "padding": "8 pixels",
          "children": [
            {
              "class_name": "chaptersubtitle",
              "name": "search_common_text",
              "box": {
                "width": "116 pixels",
                "height": "40 pixels"
              },
              "text": "    SEARCH"
            },
            {
              "class_name": "edit",
              "name": "search_input",
              "json_field_name": "full_text",
              "placholder": "Search text",
              "box": {
                "width": "216 pixels",
                "height": "32 pixels"
              },
              "text_style": {
                "font_name": "Georgia",
                "font_size": 18
              }
            },
            {
              "class_name": "chaptersubtitle",
              "name": "search_results_text",
              "box": {
                "width": "8 pixels",
                "height": "40 pixels"
              },
              "text": ""
            },
            {
              "class_name": "chaptersubtitle",
              "name": "search_prompt_text",
              "box": {
                "width": "400 pixels",
                "height": "40 pixels"
              },
              "text": "SELECT {class_name}"
            },
            {
              "class_name": "chaptersubtitle",
              "name": "edit_prompt_text",
              "box": {
                "width": "1.0 remaining",
                "height": "40 pixels"
              },
              "text": "EDIT"
            }
          ]
        },
        {
          "class_name": "row",
          "name": "search_ceremony",
          "box": {
            "width": "1.0 container",
            "height": "1.0 remaining"
          },
          "children": [
            {
              "class_name": "column",
              "name": "search_commands",
              "box": {
                "width": "350 pixels",
                "height": "1.0 container"
              },
              "view_style": {
                "box_fill_brush": {
                  "class_name": "solid_brush",
                  "color": "111121"
                },
                "box_border_brush": {
                  "class_name": "solid_brush",
                  "color": "010102"
                },
                "box_border_thickness": 4
              },
              "padding": "8 pixels",
              "wrap": true,
              "children": [
                "$search_groups"
              ]
            },

            {
              "class_name": "column",
              "name": "search_result",
              "box": {
                "width": "400 pixels",
                "height": "1.0 container"
              },
              "children": [
                {
                  "class_name": "items_view",
                  "name": "result_table",
                  "box": {
                    "width": "1.0 container",
                    "height": "1.0 container"
                  },
                  "padding": "2 pixels",
                  "sources": "card_sources",
                  "empty_text": "No items in list",
                  "empty_command": {
                    "class_name": "select_frame",
                    "target_frame": "page_home.frame_selected",
                    "source_frame": "page_empty",
                    "message": "layout test."
                  },
                  "select_command": {
                    "class_name": "list_select_object",
                    "target_frame": "page_home.frame_selected",
                    "table_name": "result_table",
                    "sources": "form_sources"
                  }
                }
              ]
            },
            {
              "class_name": "column",
              "name": "object_edit_bar",
              "box": {
                "width": "100 pixels",
                "height": "1.0 container"
              },
              "view_style": {
                "box_fill_brush": {
                  "class_name": "solid_brush",
                  "color": "111121"
                },
                "box_border_brush": {
                  "class_name": "solid_brush",
                  "color": "111112"
                },
                "box_border_thickness": 4
              },

              "children": [
                {
                  "class_name": "command_button",
                  "name": "back_object",
                  "image": "assets\\back.png",
                  "text": "back",
                  "box": {
                    "width": "100 pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "navigate",
                    "forward": false,
                    "target_frame": "frame_selected"
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "next_object",
                  "image": "assets\\forward.png",
                  "text": "forward",
                  "box": {
                    "width": "100  pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "navigate",
                    "forward": true,
                    "target_frame": "frame_selected"
                  }
                },
                {
                  "class_name": "chaptersubtitle",
                  "name": "search_label_text",
                  "box": {
                    "width": "100 pixels",
                    "height": "30 pixels"
                  },
                  "text": "Object"
                },
                {
                  "class_name": "command_button",
                  "name": "save_object",
                  "image": "assets\\save.png",
                  "text": "save",
                  "box": {
                    "width": "100  pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "save_object",
                    "form_name": "frame_selected",
                    "target_frame": "frame_selected"
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "delete_object",
                  "image": "assets\\trash.png",
                  "text": "delete",
                  "box": {
                    "width": "100  pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "delete_object",
                    "target_frame": "frame_selected"
                  }
                },
                {
                  "class_name": "chaptersubtitle",
                  "box": {
                    "width": "1.0 container",
                    "height": "30 pixels"
                  },
                  "text": "Add"
                }

              ]
            },
            {
              "class_name": "column",
              "name": "frame_bar",
              "box": {
                "width": "1.0 remaining",
                "height": "1.0 container"
              },
              "children": [
                {
                  "class_name": "column",
                  "name": "search_container",
                  "box": {
                    "width": "1.0 container",
                    "height": "1.0 remaining"
                  },
                  "padding": "8 pixels",
                  "children": [
                    {
                      "class_name": "frame",
                      "name": "frame_selected",
                      "edit_bars": [ "object_edit_bar" ],
                      "box": {
                        "width": "1.0 container",
                        "height": "1.0 remaining"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}