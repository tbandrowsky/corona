{
  "class_name": "page",
  "page_name": "page_client_credit_memo_card",
  "using": {
    "page_name": "page_object_card_template",
    "parameters": {
      "$icon_image_file": "assets\\credit_memo.png",
      "$card_height": "75 pixels",
      "$card_contents": [
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "description",
          "text_style": {
            "font_size": 16,
            "bold": true
          }
        },
        {
          "class_name": "paragraph",
          "box": "card_text_box",
          "text_field_name": "debit_account_number"
        }
      ]
    }
  }
}
