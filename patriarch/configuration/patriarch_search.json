{
  "class_name": "page",
  "page_name": "page_search",
  "default": true,
  "children": [
    {
      "class_name": "column",
      "box": "full_container",
      "children": [
        {
          "class_name": "placeholder",
          "name": "search_result",
          "text": "",
          "box": {
            "width": "1.0 container",
            "height": "16.0 pixels"
          }
        },
        {
          "class_name": "row",
          "name": "search_result",
          "box": {
            "width": "1.0 container",
            "height": "1.0 remaining"
          },
          "children": [

            {
              "class_name": "column",
              "name": "button_row",
              "box": {
                "width": "100 pixels",
                "height": "1.0 container"
              },
              "view_style": {
                "box_fill_brush": {
                  "class_name": "solid_brush",
                  "color": "111121"
                },
                "box_border_brush": {
                  "class_name": "solid_brush",
                  "color": "111112"
                },
                "box_border_thickness": 4
              },
              "children": [
                {
                  "class_name": "chaptertitle",
                  "name": "search_label_text",
                  "box": {
                    "width": "100 pixels",
                    "height": "40 pixels"
                  },
                  "text": "Find"
                },
                {
                  "class_name": "command_button",
                  "name": "search_button",
                  "icon": "CompletedTask",
                  "text": "tasks",
                  "box": {
                    "width": "100 pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "query",
                    "form_name": "search_row",
                    "table_name": "result_table",
                    "detail_frame": "frame_selected",
                    "query": {
                      "from": [
                        {
                          "class_name": "task",
                          "name": "objects",
                          "filter": {
                            "full_text": "$this.full_text"
                          }
                        }
                      ],
                      "stages": [
                        {
                          "class_name": "result",
                          "source": "objects",
                          "name": "objects"
                        }
                      ]
                    }
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "search_family",
                  "icon": "Family",
                  "text": "family",
                  "box": {
                    "width": "100 pixels",
                    "height": "50 pixels"

                  },
                  "on_click": {
                    "class_name": "query",
                    "form_name": "search_row",
                    "table_name": "result_table",
                    "detail_frame": "frame_selected",
                    "query": {
                      "from": [
                        {
                          "class_name": "member",
                          "name": "objects",
                          "filter": {
                            "full_text": "$this.full_text"
                          }
                        }
                      ],
                      "stages": [
                        {
                          "class_name": "result",
                          "source": "objects",
                          "name": "objects"
                        }
                      ]
                    }
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "search_button",
                  "icon": "HomeHouse",
                  "text": "asset",
                  "box": {
                    "width": "100 pixels",
                    "height": "50 pixels"

                  },
                  "on_click": {
                    "class_name": "query",
                    "form_name": "search_row",
                    "table_name": "result_table",
                    "detail_frame": "frame_selected",
                    "query": {
                      "from": [
                        {
                          "class_name": "asset",
                          "name": "objects",
                          "filter": {
                            "full_text": "$this.full_text"
                          }
                        }
                      ],
                      "stages": [
                        {
                          "class_name": "result",
                          "source": "objects",
                          "name": "objects"
                        }
                      ]
                    }
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "search_contacts",
                  "icon": "Contact",
                  "text": "contacts",
                  "box": {
                    "width": "100 pixels",
                    "height": "50 pixels"

                  },
                  "on_click": {
                    "class_name": "query",
                    "form_name": "search_row",
                    "table_name": "result_table",
                    "detail_frame": "frame_selected",
                    "query": {
                      "from": [
                        {
                          "class_name": "contact",
                          "name": "objects",
                          "filter": {
                            "full_text": "$this.full_text"
                          }
                        }
                      ],
                      "stages": [
                        {
                          "class_name": "result",
                          "source": "objects",
                          "name": "objects"
                        }
                      ]
                    }
                  }
                },

                {
                  "class_name": "command_button",
                  "icon": "CalendarDay",
                  "box": "button_box",
                  "margin": "button_margin",
                  "text": "today",
                  "defaults_field": "common",
                  "on_click": {
                    "class_name": "query",
                    "form_name": "search_row",
                    "table_name": "result_table",
                    "detail_frame": "frame_selected",
                    "query": {
                      "from": [
                        {
                          "class_name": "task",
                          "name": "objects",
                          "filter": {
                            "full_text": "$this.full_text"
                          }
                        }
                      ],
                      "stages": [
                        {
                          "class_name": "filter",
                          "source": "objects",
                          "name": "filtered",
                          "condition": {
                            "class_name": "all",
                            "conditions": [
                              {
                                "class_name": "gte",
                                "valuepath": "task_date",
                                "value": "$this.common.dates.today.start"
                              },
                              {
                                "class_name": "lte",
                                "valuepath": "task_date",
                                "value": "$this.common.dates.today.stop"
                              }
                            ]
                          }
                        },
                        {
                          "class_name": "result",
                          "source": "filtered",
                          "name": "output"
                        }
                      ]
                    }
                  }
                },

                {
                  "class_name": "command_button",
                  "icon": "CalendarWeek",
                  "box": "button_box",
                  "margin": "button_margin",
                  "text": "week",
                  "defaults_field": "common",
                  "on_click": {
                    "class_name": "query",
                    "form_name": "search_row",
                    "table_name": "result_table",
                    "detail_frame": "frame_selected",
                    "query": {
                      "from": [
                        {
                          "class_name": "task",
                          "name": "objects",
                          "filter": {
                            "full_text": "$this.full_text"
                          }
                        }
                      ],
                      "stages": [
                        {
                          "class_name": "filter",
                          "source": "objects",
                          "condition": {
                            "class_name": "all",
                            "conditions": [
                              {
                                "class_name": "gte",
                                "valuepath": "task_date",
                                "value": "$this.common.dates.this_week.start"
                              },
                              {
                                "class_name": "lte",
                                "valuepath": "task_date",
                                "value": "$this.common.dates.this_week.stop"
                              }
                            ]
                          },
                          "name": "filtered"
                        },
                        {
                          "class_name": "result",
                          "source": "filtered",
                          "name": "output"
                        }
                      ]
                    }
                  }
                },

                {
                  "class_name": "command_button",
                  "name": "search_all",
                  "icon": "ViewAll",
                  "text": "everything",
                  "box": {
                    "width": "100 pixels",
                    "height": "50 pixels"

                  },
                  "on_click": {
                    "class_name": "query",
                    "form_name": "search_row",
                    "table_name": "result_table",
                    "detail_frame": "frame_selected",
                    "query": {
                      "from": [
                        {
                          "class_name": "patriarch_object",
                          "name": "objects",
                          "filter": {
                            "full_text": "$this.full_text"
                          }
                        }
                      ],
                      "stages": [
                        {
                          "class_name": "result",
                          "source": "objects",
                          "name": "objects"
                        }
                      ]
                    }
                  }
                },
                {
                  "class_name": "chaptertitle",
                  "name": "search_placxe",
                  "text": "",
                  "box": {
                    "width": "100 pixels",
                    "height": "16.0 pixels"
                  }
                }
              ]
            },
            {
              "class_name": "column",
              "name": "search_result",
              "box": {
                "width": "400 pixels",
                "height": "1.0 remaining"
              },
              "children": [
                {
                  "class_name": "chaptertitle",
                  "name": "search_label_text",
                  "box": {
                    "width": "1.0 container",
                    "height": "40 pixels"
                  },
                  "text": "List"
                },
                {
                  "class_name": "items_view",
                  "name": "result_table",
                  "box": {
                    "width": "400 pixels",
                    "height": "1.0 remaining"
                  },
                  "padding": "2 pixels",
                  "sources": "card_sources",
                  "empty_text": "No items in list",
                  "empty_command": {
                    "class_name": "select_frame",
                    "target_frame": "page_home.frame_selected",
                    "source_frame": "page_empty",
                    "message": "layout test."
                  },
                  "select_command": {
                    "class_name": "list_select_object",
                    "target_frame": "page_home.frame_selected",
                    "table_name": "result_table",
                    "sources": "form_sources"
                  }
                },
                {
                  "class_name": "row",
                  "name": "search_row",
                  "box": {
                    "width": "1.0 container",
                    "height": "50 pixels"
                  },
                  "children": [
                    {
                      "class_name": "chaptertitle",
                      "name": "search_label_text",
                      "box": {
                        "width": "100 pixels",
                        "height": "40 pixels"
                      },
                      "text": "Filter"
                    },
                    {
                      "class_name": "edit",
                      "name": "search_input",
                      "json_field_name": "full_text",
                      "placholder": "Search text",
                      "box": {
                        "width": "300 pixels",
                        "height": "40 pixels"
                      },
                      "text_style": {
                        "font_name": "Georgia",
                        "font_size": 24
                      }
                    }
                  ]
                }
              ]
            },
            {
              "class_name": "column",
              "name": "search_row2",
              "box": {
                "width": "100 pixels",
                "height": "1.0 container"
              },
              "view_style": {
                "box_fill_brush": {
                  "class_name": "solid_brush",
                  "color": "111121"
                },
                "box_border_brush": {
                  "class_name": "solid_brush",
                  "color": "111112"
                },
                "box_border_thickness": 4
              },

              "children": [
                {
                  "class_name": "chaptertitle",
                  "name": "search_label_text",
                  "box": {
                    "width": "100 pixels",
                    "height": "40 pixels"
                  },
                  "text": "Edit"
                },
                {
                  "class_name": "command_button",
                  "name": "new_button",
                  "icon": "Add",
                  "text": "new item",
                  "box": {
                    "width": "100 pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "select_frame",
                    "target_frame": "page_home.frame_selected",
                    "source_frame": "page_create",
                    "message": "new item."
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "new_note",
                  "icon": "Note",
                  "text": "add note",
                  "box": {
                    "width": "100 pixels",
                    "height": "50 pixels"

                  },
                  "on_click": {
                    "class_name": "create_object",
                    "create_class_name": "patriarch_note",
                    "constructor_frame": "frame_selected",
                    "constructor_copy": {
                      "patriarch_object": "object_id",
                      "patriarch_object_class": "class_name"
                    },
                    "source_frame": "page_note",
                    "target_frame": "frame_selected",
                    "message": "layout test."
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "save_object",
                  "icon": "Save",
                  "text": "save",
                  "box": {
                    "width": "100  pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "save_object",
                    "form_name": "frame_selected",
                    "target_frame": "frame_selected"
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "back_object",
                  "icon": "Back",
                  "text": "back",
                  "box": {
                    "width": "100  pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "navigate",
                    "forward":  false,
                    "target_frame": "frame_selected"
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "next_object",
                  "icon": "Forward",
                  "text": "forward",
                  "box": {
                    "width": "100  pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "navigate",
                    "forward": true,
                    "target_frame": "frame_selected"
                  }
                },
                {
                  "class_name": "command_button",
                  "name": "delete_object",
                  "icon": "Delete",
                  "text": "delete",
                  "box": {
                    "width": "100  pixels",
                    "height": "50 pixels"
                  },
                  "on_click": {
                    "class_name": "delete_object",
                    "target_frame": "frame_selected"
                  }
                }

              ]
            },
            {
              "class_name": "column",
              "name": "search_row2",
              "box": {
                "width": "1.0 remaining",
                "height": "1.0 container"
              },
              "children": [
                {
                  "class_name": "chaptertitle",
                  "name": "search_label_text",
                  "box": {
                    "width": "1.0 container",
                    "height": "40 pixels"
                  },
                  "text": ""
                },
                {
                  "class_name": "column",
                  "name": "search_row3",
                  "box": {
                    "width": "1.0 container",
                    "height": "1.0 remaining"
                  },
                  "padding": "8 pixels",
                  "children": [
                    {
                      "class_name": "frame",
                      "name": "frame_selected",
                      "box": {
                        "width": "1.0 container",
                        "height": "1.0 remaining"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}